# === Driveway Detail Co — Environment Variables ===
# Copy to .env and fill in real values

# --- App ---
PHX_HOST=drivewaydetail.co
PHX_SERVER=true
PORT=4000
SECRET_KEY_BASE=generate_with_mix_phx_gen_secret
TOKEN_SIGNING_SECRET=generate_with_mix_phx_gen_secret

# --- Database (DigitalOcean Managed PostgreSQL) ---
DATABASE_URL=ecto://user:password@db-host:25060/mobile_car_wash?ssl=true
POOL_SIZE=10

# --- Stripe ---
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- S3 Photo Storage (DigitalOcean Spaces) ---
S3_BUCKET=driveway-detail-photos
AWS_ACCESS_KEY_ID=DO_SPACES_KEY
AWS_SECRET_ACCESS_KEY=DO_SPACES_SECRET
AWS_REGION=nyc3

# --- S3 Endpoint (DigitalOcean Spaces uses custom endpoint) ---
AWS_S3_ENDPOINT=https://nyc3.digitaloceanspaces.com

# --- Google Analytics (optional — leave empty to disable) ---
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
