<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <meta
      name="description"
      content={
        assigns[:meta_description] ||
          "Driveway Detail Co — professional mobile car wash and detailing. We come to your home or office. Veteran-owned. Book online in minutes."
      }
    />
    <meta
      name="keywords"
      content={
        assigns[:meta_keywords] ||
          "mobile car wash, mobile detailing, car detail, auto detailing, driveway detail, veteran owned, car wash at home, mobile car wash near me"
      }
    />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#1e293b" />
    <link
      rel="canonical"
      href={"https://drivewaydetailcosa.com#{assigns[:canonical_path] || "/"}"}
    />
    
<!-- Favicon -->
    <link rel="icon" type="image/x-icon" href={~p"/images/favicon-v2.ico"} />
    <link rel="icon" type="image/png" sizes="16x16" href={~p"/images/favicon-v2-16.png"} />
    <link rel="icon" type="image/png" sizes="32x32" href={~p"/images/favicon-v2-32.png"} />
    <link rel="apple-touch-icon" sizes="180x180" href={~p"/images/apple-touch-icon-v2.png"} />
    <link rel="icon" type="image/png" sizes="192x192" href={~p"/images/android-chrome-v2-192.png"} />
    <link rel="icon" type="image/png" sizes="512x512" href={~p"/images/android-chrome-v2-512.png"} />
    
<!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Driveway Detail Co" />
    <meta property="og:locale" content="en_US" />
    <meta
      property="og:title"
      content={assigns[:page_title] || "Driveway Detail Co — Mobile Detailing"}
    />
    <meta
      property="og:description"
      content={
        assigns[:meta_description] ||
          "Professional mobile car wash and detailing at your door. Veteran-owned. Book online."
      }
    />
    <meta
      property="og:url"
      content={"https://drivewaydetailcosa.com#{assigns[:canonical_path] || "/"}"}
    />
    <meta property="og:image" content="https://drivewaydetailcosa.com/images/og-share.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    
<!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta
      name="twitter:title"
      content={assigns[:page_title] || "Driveway Detail Co — Mobile Detailing"}
    />
    <meta
      name="twitter:description"
      content={
        assigns[:meta_description] ||
          "Professional mobile car wash and detailing at your door. Veteran-owned."
      }
    />
    <meta name="twitter:image" content="https://drivewaydetailcosa.com/images/og-share.png" />
    
<!-- Preconnect for external resources -->
    <link rel="preconnect" href="https://www.googletagmanager.com" />
    <link :if={assigns[:preconnect_tiles]} rel="preconnect" href="https://tiles.stadiamaps.com" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@500;600;700&display=swap"
      rel="stylesheet"
    />

    <.live_title default="Driveway Detail Co" suffix=" · Mobile Detailing">
      {assigns[:page_title]}
    </.live_title>
    <link phx-track-static rel="preload" as="style" href={~p"/assets/css/app.css"} />
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script
      defer
      phx-track-static
      type="text/javascript"
      nonce={@conn.assigns.csp_nonce}
      src={~p"/assets/js/app.js"}
    >
    </script>
    <%= if ga_id = Application.get_env(:mobile_car_wash, :google_analytics_id) do %>
      <meta name="ga-id" content={ga_id} />
      <script defer nonce={@conn.assigns.csp_nonce} src={~p"/assets/js/ga-init.js"}>
      </script>
    <% end %>
  </head>
  <body>
    {@inner_content}
    <MobileCarWashWeb.Layouts.cookie_banner
      :if={is_nil(assigns[:current_consent])}
      conn={@conn}
    />
  </body>
</html>
